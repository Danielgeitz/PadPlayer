 193:../../libDaisy//src/hid/disp/display.h **** /** This class is intended as a intermediary class for your actual implementation of the OneBitGrap
 194:../../libDaisy//src/hid/disp/display.h ****  *  interface. It uses the CRTP design pattern where the template argument is the child class. It p
 195:../../libDaisy//src/hid/disp/display.h ****  *  implementations for most of the functions, except DrawPixel(), Update() and Fill(), which you'l
 196:../../libDaisy//src/hid/disp/display.h ****  *  to provide in your child class.
 197:../../libDaisy//src/hid/disp/display.h ****  *  The main goal of this class is to provide common drawing functions without relying on massive a
 198:../../libDaisy//src/hid/disp/display.h ****  *  virtual function calls that would result in a performance loss. To achieve this, any drawing fu
 199:../../libDaisy//src/hid/disp/display.h ****  *  is implemented here and internally calls other drawing functions (e.g. DrawRect() which interna
 200:../../libDaisy//src/hid/disp/display.h ****  *  DrawPixel() and DrawLine()) makes these calls via the qualified name of these functions to expl
 201:../../libDaisy//src/hid/disp/display.h ****  *  suppress the virtual dispatch mechanism like this:
 202:../../libDaisy//src/hid/disp/display.h ****  * 
 203:../../libDaisy//src/hid/disp/display.h ****  *      ChildType::DrawPixel(...); // no virtual function call; direct call into the child class fu
 204:../../libDaisy//src/hid/disp/display.h ****  *  
 205:../../libDaisy//src/hid/disp/display.h ****  *  To create a custom OneBitGraphicsDisplay implementation, you can 
 206:../../libDaisy//src/hid/disp/display.h ****  *  A) inherit from OneBitGraphicsDisplay directly and provide all the drawing functions yourself
 207:../../libDaisy//src/hid/disp/display.h ****  *  B) Inherit from OneBitGraphicsDisplayImpl and only provide DrawPixel(), Fill() and Update()
 208:../../libDaisy//src/hid/disp/display.h ****  *     like this:
 209:../../libDaisy//src/hid/disp/display.h ****  *  
 210:../../libDaisy//src/hid/disp/display.h ****  *      class MyDisplayClass : public OneBitGraphicsDisplayImpl<MyDisplayClass> 
 211:../../libDaisy//src/hid/disp/display.h ****  *      {
 212:../../libDaisy//src/hid/disp/display.h ****  *      public:
 213:../../libDaisy//src/hid/disp/display.h ****  *          void Fill() override { ... };
 214:../../libDaisy//src/hid/disp/display.h ****  *          void DrawPixel(uint_fast8_t x, uint_fast8_t y, bool on) override { ... };
 215:../../libDaisy//src/hid/disp/display.h ****  *          void Update() override { ... }
 216:../../libDaisy//src/hid/disp/display.h ****  *      };
 217:../../libDaisy//src/hid/disp/display.h ****  *  
 218:../../libDaisy//src/hid/disp/display.h ****  */
 219:../../libDaisy//src/hid/disp/display.h **** template <class ChildType>
 220:../../libDaisy//src/hid/disp/display.h **** class OneBitGraphicsDisplayImpl : public OneBitGraphicsDisplay
 221:../../libDaisy//src/hid/disp/display.h **** {
 222:../../libDaisy//src/hid/disp/display.h ****   public:
 223:../../libDaisy//src/hid/disp/display.h ****     OneBitGraphicsDisplayImpl() {}
