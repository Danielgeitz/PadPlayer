 220:../../libDaisy//src/dev/oled_ssd130x.h ****   private:
 221:../../libDaisy//src/dev/oled_ssd130x.h ****     void SoftSpiTransmit(uint8_t val)
 222:../../libDaisy//src/dev/oled_ssd130x.h ****     {
 223:../../libDaisy//src/dev/oled_ssd130x.h ****         // bit flip
 224:../../libDaisy//src/dev/oled_ssd130x.h ****         val = ((val & 0x01) << 7) | ((val & 0x02) << 5) | ((val & 0x04) << 3)
 225:../../libDaisy//src/dev/oled_ssd130x.h ****               | ((val & 0x08) << 1) | ((val & 0x10) >> 1) | ((val & 0x20) >> 3)
