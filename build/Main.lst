  31:Metronome.h   ****                 tapCount_++;
  32:Metronome.h   **** 
  33:Metronome.h   ****                 unsigned int sum   = 0;
  34:Metronome.h   ****                 int          count = 0;
  35:Metronome.h   ****                 for(int i = 0; i < TAP_BUFFER_SIZE; i++)
