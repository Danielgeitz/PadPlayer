   3:../../libDaisy//src/util/WavParser.h **** // Minimal, allocation-free WAV (RIFF) parser suitable for embedded (e.g.,
   4:../../libDaisy//src/util/WavParser.h **** // STM32). Supports canonical PCM / IEEE float WAV, handles JUNK and unknown
   5:../../libDaisy//src/util/WavParser.h **** // chunks by skipping.
   6:../../libDaisy//src/util/WavParser.h **** // Does not load sample data; records data offset & length
   7:../../libDaisy//src/util/WavParser.h **** // so caller can stream.
   8:../../libDaisy//src/util/WavParser.h **** //
   9:../../libDaisy//src/util/WavParser.h **** // Limitations / Assumptions:
  10:../../libDaisy//src/util/WavParser.h **** // - Little-endian host or platform where manual LE decoding is used (safe on
  11:../../libDaisy//src/util/WavParser.h **** // STM32/Cortex-M).
  12:../../libDaisy//src/util/WavParser.h **** // - No dynamic allocation; fixed maximum number of metadata entries.
  13:../../libDaisy//src/util/WavParser.h **** // - Ignores extensible format extra fields beyond what is necessary for basic
  14:../../libDaisy//src/util/WavParser.h **** // parsing.
  15:../../libDaisy//src/util/WavParser.h **** // - Caller provides an abstract Reader (seek + read) so this can work with
  16:../../libDaisy//src/util/WavParser.h **** // FatFS, cstdio, raw data, etc.
  17:../../libDaisy//src/util/WavParser.h **** //
  18:../../libDaisy//src/util/WavParser.h **** // Typical usage:
  19:../../libDaisy//src/util/WavParser.h **** //   FileReader fr(fopen("file.wav", "rb"));
  20:../../libDaisy//src/util/WavParser.h **** //   WavParser parser;
  21:../../libDaisy//src/util/WavParser.h **** //   if(parser.parse(fr)) {
  22:../../libDaisy//src/util/WavParser.h **** //      // Use parser.info() to get format, sampleRate, etc.
  23:../../libDaisy//src/util/WavParser.h **** //      // Use parser.dataOffset(), parser.dataSize() to stream audio.
  24:../../libDaisy//src/util/WavParser.h **** //   }
  25:../../libDaisy//src/util/WavParser.h **** //
  26:../../libDaisy//src/util/WavParser.h **** 
