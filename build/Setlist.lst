  44:Setlist.cpp   **** 
  45:Setlist.cpp   **** bool Setlist::ParseLine(const char* line, SetlistEntry& entry)
  46:Setlist.cpp   **** {
  47:Setlist.cpp   ****     // Expected format: "A_Soft Pad, 120, 4/4"
  48:Setlist.cpp   ****     // Make a mutable copy to tokenize
  49:Setlist.cpp   ****     char buf[128];
  50:Setlist.cpp   ****     strncpy(buf, line, sizeof(buf) - 1);
  51:Setlist.cpp   ****     buf[sizeof(buf) - 1] = '\0';
  52:Setlist.cpp   **** 
  53:Setlist.cpp   ****     // Split on commas
  54:Setlist.cpp   ****     char* token1 = strtok(buf, ",");  // "A_Soft Pad"
  55:Setlist.cpp   ****     char* token2 = strtok(NULL, ","); // " 120"
  56:Setlist.cpp   ****     char* token3 = strtok(NULL, ","); // " 4/4"
  57:Setlist.cpp   **** 
  58:Setlist.cpp   ****     if(!token1 || !token2 || !token3)
  59:Setlist.cpp   ****         return false;
  60:Setlist.cpp   **** 
  61:Setlist.cpp   ****     // Trim leading spaces
  62:Setlist.cpp   ****     while(*token1 == ' ')
  63:Setlist.cpp   ****         token1++;
  64:Setlist.cpp   ****     while(*token2 == ' ')
  65:Setlist.cpp   ****         token2++;
  66:Setlist.cpp   ****     while(*token3 == ' ')
  67:Setlist.cpp   ****         token3++;
  68:Setlist.cpp   **** 
  69:Setlist.cpp   ****     // Parse key and name from token1
  70:Setlist.cpp   ****     ParseKeyAndName(token1, entry);
  71:Setlist.cpp   **** 
  72:Setlist.cpp   ****     // Build filename and filepath
  73:Setlist.cpp   ****     snprintf(entry.filename, sizeof(entry.filename), "%s.wav", token1);
  74:Setlist.cpp   ****     snprintf(
  75:Setlist.cpp   ****         entry.filepath, sizeof(entry.filepath), "%s%s.wav", PADS_PATH, token1);
ARM GAS  C:\Users\danig\AppData\Local\Temp\ccME2Gi7.s 			page 4


  76:Setlist.cpp   **** 
  77:Setlist.cpp   ****     // Parse BPM
  78:Setlist.cpp   ****     entry.bpm = atoi(token2);
  79:Setlist.cpp   ****     if(entry.bpm <= 0 || entry.bpm > 400)
  80:Setlist.cpp   ****         return false;
  81:Setlist.cpp   **** 
  82:Setlist.cpp   ****     // Parse time signature
  83:Setlist.cpp   ****     ParseTimeSignature(token3, entry.numerator, entry.denominator);
  84:Setlist.cpp   ****     if(entry.numerator <= 0 || entry.denominator <= 0)
  85:Setlist.cpp   ****         return false;
  86:Setlist.cpp   **** 
  87:Setlist.cpp   ****     entry.valid = true;
  88:Setlist.cpp   ****     return true;
  89:Setlist.cpp   **** }
