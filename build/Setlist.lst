  37:Setlist.cpp   ****         // if ParseLine fails we just skip this line
  38:Setlist.cpp   ****     }
  39:Setlist.cpp   **** 
  40:Setlist.cpp   ****     sd_.CloseFile();
  41:Setlist.cpp   ****     loaded_ = count_ > 0;
  42:Setlist.cpp   ****     return loaded_;
