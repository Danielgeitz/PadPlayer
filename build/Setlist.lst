  20:Setlist.cpp   **** 
  21:Setlist.cpp   ****     char line[128];
  22:Setlist.cpp   ****     int  lineNum = 0;
  23:Setlist.cpp   **** 
  24:Setlist.cpp   ****     while(sd_.ReadLine(line, sizeof(line)) && count_ < 12)
  25:Setlist.cpp   ****     {
  26:Setlist.cpp   ****         lineNum++;
  27:Setlist.cpp   **** 
  28:Setlist.cpp   ****         // Skip empty lines and comments
  29:Setlist.cpp   ****         if(line[0] == '\0' || line[0] == '#')
  30:Setlist.cpp   ****             continue;
  31:Setlist.cpp   **** 
